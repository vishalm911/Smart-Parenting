rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── USERS ──────────────────────────────────────────
    // Each user can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── GAME CONTENT (Ayush owns) ──────────────────────
    // Publicly readable, only admin can write
    match /math_games/{doc} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }
    match /puzzle_games/{doc} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }
    match /logic_games/{doc} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // ── SCORES ─────────────────────────────────────────
    // Authenticated users can create; read only own records
    match /numeracy_scores/{doc} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null && resource.data.child_id == request.auth.uid;
      allow update, delete: if false;
    }

    // ── PROGRESS TRACKING (cross-module writes) ────────
    match /progress_tracking/{doc} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null && resource.data.child_id == request.auth.uid;
      allow update, delete: if false;
    }

    // ── STREAKS ────────────────────────────────────────
    // Each user manages their own streak doc
    match /streaks/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── SESSIONS ───────────────────────────────────────
    match /sessions/{doc} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null && resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    // ── ACHIEVEMENTS ───────────────────────────────────
    match /achievements/{doc} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null && resource.data.child_id == request.auth.uid;
      allow update, delete: if false;
    }

    // ── NOTIFICATIONS ──────────────────────────────────
    match /notifications/{doc} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null &&
                    (resource.data.child_id == request.auth.uid ||
                     resource.data.parent_id == request.auth.uid);
      allow update: if request.auth != null && resource.data.parent_id == request.auth.uid;
      allow delete: if false;
    }

    // ── REWARDS (read-only for all authenticated users) ─
    match /rewards/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // ── USER ACCOUNTS ───────────────────────────────────
    match /user_accounts/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── AVATARS ──────────────────────────────────────────
    match /avatars/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // ── CHILD PROFILES ───────────────────────────────────
    match /child_profiles/{doc} {
      allow read:  if request.auth != null && resource.data.parent_uid == request.auth.uid;
      allow write: if request.auth != null && request.resource.data.parent_uid == request.auth.uid;
    }

    // ── AI ANALYSIS ──────────────────────────────────────
    match /ai_analysis/{doc} {
      allow read: if request.auth != null && resource.data.child_id == request.auth.uid;
      allow write: if false; // Cloud Function only
    }

    // ── ASSESSMENTS ──────────────────────────────────────
    match /assessments/{doc} {
      allow read:   if request.auth != null && resource.data.child_id == request.auth.uid;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ── RECOMMENDATIONS ──────────────────────────────────
    match /recommendations/{doc} {
      allow read: if request.auth != null && resource.data.child_id == request.auth.uid;
      allow write: if false;
    }

    // ── REPORTS ──────────────────────────────────────────
    match /reports/{doc} {
      allow read: if request.auth != null &&
                  (resource.data.child_id == request.auth.uid ||
                   resource.data.parent_id == request.auth.uid);
      allow write: if false;
    }

    // ── FEATURE FLAGS (backend intern — read only) ──────
    match /feature_flags/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // ── APP CONFIG (backend intern — read only) ─────────
    match /app_config/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // ── ADMIN ONLY COLLECTIONS ──────────────────────────
    match /admins/{doc} {
      allow read, write: if request.auth != null && isAdmin();
    }
    match /audit_logs/{doc} {
      allow read: if request.auth != null && isAdmin();
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
    match /notification_templates/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // ── LITERACY (other interns — read only where needed) ─
    match /stories/{doc}              { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /reading_activities/{doc}   { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /vocabulary_games/{doc}     { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /phonics_words/{doc}        { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /fluency_passages/{doc}     { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /language_scores/{doc}      {
      allow create: if request.auth != null;
      allow read:   if request.auth != null && resource.data.child_id == request.auth.uid;
      allow update, delete: if false;
    }
    match /reading_progress/{doc}     {
      allow read, write: if request.auth != null && resource.data.child_id == request.auth.uid;
    }

    // ── COGNITIVE (Yogeshwar — read only where needed) ──
    match /cognitive_games/{doc}       { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /creativity_activities/{doc} { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /emotion_activities/{doc}    { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /uploaded_assets/{doc}       { allow read, create, update: if request.auth != null; allow delete: if isAdmin(); }
    match /cognitive_scores/{doc}      { allow read: if request.auth != null; allow create, update: if request.auth != null; allow delete: if isAdmin(); }
    match /emotion_scores/{doc}        { allow read: if request.auth != null; allow create, update: if request.auth != null; allow delete: if isAdmin(); }

    // ── HELPER FUNCTION ─────────────────────────────────
    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
  }
}
